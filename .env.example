# Copy this file to ".env" or set these variables in your hosting provider.
# When using Vite the variables must be prefixed with VITE_
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# For server-side (admin) access you can provide a base64-encoded service account JSON
# e.g. in bash: export FIREBASE_SERVICE_ACCOUNT=$(base64 -w0 serviceAccountKey.json)
# or set the raw path via GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT=
